## 完整代码

```javascript
// server/src/lib/ai.js
export class AIClient {
  constructor() {
    this._apiKey = null;
    this._baseUrl = null;
    this._isOpenAIFormat = null;
  }

  get apiKey() {
    if (!this._apiKey) this._apiKey = process.env.GEMINI_API_KEY;
    return this._apiKey;
  }

  get baseUrl() {
    if (!this._baseUrl) {
      this._baseUrl = process.env.GEMINI_BASE_URL ||
        'https://generativelanguage.googleapis.com/v1beta/models';
    }
    return this._baseUrl;
  }

  get isOpenAIFormat() {
    if (this._isOpenAIFormat === null) {
      this._isOpenAIFormat = !this.baseUrl.includes('generativelanguage.googleapis.com');
    }
    return this._isOpenAIFormat;
  }

  async generate(prompt, options = {}) {
    const model = options.model || 'gemini-3.1-pro-preview';
    const maxTokens = options.maxTokens || 8192;

    if (this.isOpenAIFormat) {
      const url = `${this.baseUrl}/v1/chat/completions`;
      const res = await fetch(url, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${this.apiKey}`,
        },
        body: JSON.stringify({
          model,
          messages: [{ role: 'user', content: prompt }],
          max_tokens: maxTokens,
        }),
      });
      const data = await res.json();
      return data.choices?.[0]?.message?.content || '';
    } else {
      const res = await fetch(
        `${this.baseUrl}/${model}:generateContent?key=${this.apiKey}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{ parts: [{ text: prompt }] }],
            generationConfig: { maxOutputTokens: maxTokens },
          }),
        }
      );
      const data = await res.json();
      return data.candidates?.[0]?.content?.parts?.[0]?.text || '';
    }
  }

  async generateJSON(prompt, options = {}) {
    const text = await this.generate(
      prompt + '\n\n只输出 JSON，不要 markdown 代码块，不要其他内容。',
      options
    );
    let jsonStr = text;
    const codeBlockMatch = text.match(/```(?:json)?\s*([\s\S]*?)```/);
    if (codeBlockMatch) {
      jsonStr = codeBlockMatch[1].trim();
    } else {
      const braceMatch = text.match(/\{[\s\S]*\}/);
      if (braceMatch) jsonStr = braceMatch[0];
    }
    try {
      return JSON.parse(jsonStr);
    } catch (e) {
      console.error('JSON parse error:', e.message);
      return null;
    }
  }
}

export const ai = new AIClient();
```

