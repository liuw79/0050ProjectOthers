# AI教练报告 JSON Schema

## 概述

定义 AI 教练评估报告的结构化数据格式，用于：
1. 指导 Gemini 输出结构化 JSON
2. 渲染成 HTML 报告

---

## JSON Schema

```json
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["score", "summary", "dimensions", "bonus", "suggestions", "ending", "target"],
  "properties": {
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "总分（0-100）"
    },
    "summary": {
      "type": "string",
      "description": "一句话总评"
    },
    "dimensions": {
      "type": "array",
      "description": "分项评分（6个维度）",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["name", "weight", "score", "max", "detail"],
        "properties": {
          "name": { "type": "string", "description": "维度名称" },
          "weight": { "type": "string", "description": "权重，如'30%'" },
          "score": { "type": "integer", "description": "得分" },
          "max": { "type": "integer", "description": "满分" },
          "highlight": { "type": "string", "description": "亮点（可选）" },
          "detail": { "type": "string", "description": "详细说明" },
          "suggested_script": { "type": "string", "description": "建议话术（可选）" }
        }
      }
    },
    "bonus": {
      "type": "array",
      "description": "高阶加分项",
      "items": {
        "type": "object",
        "required": ["title", "points", "detail"],
        "properties": {
          "title": { "type": "string", "description": "加分项名称" },
          "points": { "type": "integer", "enum": [1, 3, 5], "description": "加分值（+1/+3/+5）" },
          "original": { "type": "string", "description": "原稿表达（可选）" },
          "golden_sentence": { "type": "string", "description": "现场金句（可选）" },
          "detail": { "type": "string", "description": "分析说明" }
        }
      }
    },
    "suggestions": {
      "type": "array",
      "description": "AI教练建议（Top 3）",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["title", "problem_type", "performance", "insight", "suggestion"],
        "properties": {
          "title": { "type": "string", "description": "建议标题" },
          "problem_type": { "type": "string", "description": "问题类型" },
          "performance": { "type": "string", "description": "具体表现" },
          "insight": { "type": "string", "description": "深度洞察" },
          "suggestion": { "type": "string", "description": "优化建议" },
          "suggested_script": { "type": "string", "description": "建议话术" }
        }
      }
    },
    "ending": {
      "type": "string",
      "description": "结束语（个性化寄语）"
    },
    "target": {
      "type": "object",
      "required": ["name", "course"],
      "properties": {
        "name": { "type": "string", "description": "班主任姓名" },
        "course": { "type": "string", "description": "课程名称" }
      }
    }
  }
}
```

---

## 维度定义（固定顺序）

| 序号 | name | weight | max |
|------|------|--------|-----|
| 1 | 高维介绍 | 30% | 30 |
| 2 | 产品介绍 | 30% | 30 |
| 3 | 团建破冰 | 5% | 5 |
| 4 | 邀约课评 | 15% | 15 |
| 5 | 结尾升华 | 10% | 10 |
| 6 | 口语节奏 | 10% | 10 |

