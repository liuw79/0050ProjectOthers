#!/usr/bin/env node
/**
 * Gemini API CLI Tool
 * 用法：
 *   node gemini.js "你的prompt"
 *   node gemini.js --json "生成JSON的prompt"
 *   node gemini.js --system "系统提示词" "用户提示词"
 *   node gemini.js --file prompt.txt
 */

const https = require('https');
const fs = require('fs');
const path = require('path');

// 加载环境变量
function loadEnv() {
  const envPath = path.join(__dirname, '.env');
  if (fs.existsSync(envPath)) {
    const content = fs.readFileSync(envPath, 'utf-8');
    content.split('\n').forEach(line => {
      const match = line.match(/^([^#=]+)=(.*)$/);
      if (match) {
        const key = match[1].trim();
        const value = match[2].trim().replace(/^["']|["']$/g, '');
        if (!process.env[key]) {
          process.env[key] = value;
        }
      }
    });
  }
}

loadEnv();

const baseUrl = process.env.GEMINI_BASE_URL || 'https://api.openai-proxy.org';
const apiKey = process.env.GEMINI_API_KEY;
const defaultModel = process.env.GEMINI_MODEL || 'gemini-3.1-pro-preview';

if (!apiKey) {
  console.error('错误: GEMINI_API_KEY 未设置');
  console.error('请在 .env 文件中设置：GEMINI_API_KEY=your-key');
  process.exit(1);
}

function generate(messages, options = {}) {
  return new Promise((resolve, reject) => {
    const model = options.model || defaultModel;
    const maxTokens = options.maxTokens || 8192;

    const payload = {
      model,
      messages,
      max_tokens: maxTokens
    };

    const url = new URL(baseUrl + '/v1/chat/completions');

    const reqOptions = {
      hostname: url.hostname,
      port: url.port || 443,
      path: url.pathname,
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${apiKey}`
      }
    };

    const req = https.request(reqOptions, (res) => {
      let data = '';
      res.on('data', chunk => data += chunk);
      res.on('end', () => {
        try {
          const json = JSON.parse(data);
          if (json.error) {
            reject(new Error(json.error.message || JSON.stringify(json.error)));
          } else if (json.choices && json.choices[0]) {
            resolve(json.choices[0].message.content);
          } else {
            reject(new Error('Unexpected response: ' + data));
          }
        } catch (e) {
          reject(new Error('Parse error: ' + e.message + '\n' + data));
        }
      });
    });

    req.on('error', reject);
    req.write(JSON.stringify(payload));
    req.end();
  });
}

function extractJSON(text) {
  // 尝试从 markdown 代码块中提取
  const codeBlockMatch = text.match(/```(?:json)?\s*([\s\S]*?)```/);
  if (codeBlockMatch) {
    return codeBlockMatch[1].trim();
  }
  // 尝试匹配花括号
  const braceMatch = text.match(/\{[\s\S]*\}/);
  if (braceMatch) {
    return braceMatch[0];
  }
  return text;
}

async function main() {
  const args = process.argv.slice(2);

  if (args.length === 0 || args[0] === '--help' || args[0] === '-h') {
    console.log(`
Gemini API CLI Tool

用法：
  gemini "你的prompt"                     # 简单文本生成
  gemini --json "生成JSON"                # JSON输出模式
  gemini --system "系统词" "用户词"        # 带系统提示词
  gemini --file prompt.txt                # 从文件读取

选项：
  --json          强制JSON输出
  --system        设置系统提示词
  --file          从文件读取prompt
  --model         指定模型（默认：gemini-3.1-pro-preview）
  --max-tokens    最大token数（默认：8192）

示例：
  gemini "用一句话介绍高维学堂"
  gemini --json "生成一个包含name和age的JSON"
  gemini --system "你是营销专家" "帮我写个标题"
  gemini --file prompt.txt
`);
    process.exit(0);
  }

  let systemPrompt = '';
  let userPrompt = '';
  let isJSON = false;
  let model = defaultModel;
  let maxTokens = 8192;

  // 解析参数
  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--json') {
      isJSON = true;
    } else if (args[i] === '--system') {
      systemPrompt = args[++i] || '';
    } else if (args[i] === '--file') {
      const filePath = args[++i];
      if (filePath && fs.existsSync(filePath)) {
        userPrompt = fs.readFileSync(filePath, 'utf-8');
      } else {
        console.error(`文件不存在: ${filePath}`);
        process.exit(1);
      }
    } else if (args[i] === '--model') {
      model = args[++i] || defaultModel;
    } else if (args[i] === '--max-tokens') {
      maxTokens = parseInt(args[++i]) || 8192;
    } else if (!args[i].startsWith('--')) {
      if (!userPrompt) {
        userPrompt = args[i];
      }
    }
  }

  // 如果还有第二个非选项参数，作为用户prompt
  const nonOptionArgs = args.filter(a => !a.startsWith('--'));
  if (nonOptionArgs.length > 1 && !systemPrompt) {
    // 如果没有 --system 但有两个参数，第一个是系统词
    // 这个逻辑已被 --system 覆盖
  }

  if (!userPrompt) {
    console.error('错误: 请提供 prompt');
    process.exit(1);
  }

  // JSON模式添加后缀
  if (isJSON) {
    userPrompt += '\n\n只输出 JSON，不要 markdown 代码块，不要其他内容。';
  }

  // 构建消息
  const messages = [];
  if (systemPrompt) {
    messages.push({ role: 'system', content: systemPrompt });
  }
  messages.push({ role: 'user', content: userPrompt });

  try {
    const result = await generate(messages, { model, maxTokens });

    if (isJSON) {
      const jsonStr = extractJSON(result);
      try {
        const json = JSON.parse(jsonStr);
        console.log(JSON.stringify(json, null, 2));
      } catch (e) {
        console.error('JSON解析失败，原始输出：');
        console.log(result);
      }
    } else {
      console.log(result);
    }
  } catch (error) {
    console.error('错误:', error.message);
    process.exit(1);
  }
}

main();
