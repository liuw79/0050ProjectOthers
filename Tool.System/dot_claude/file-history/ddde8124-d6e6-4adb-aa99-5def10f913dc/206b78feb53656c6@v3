node coach.js --course "xxx" --teacher "xxx" --date "xxx"

# 2. 在 Claude Code 中发布
> 发布到飞书，分享给 xxx@gaowei.com
```

### MCP 工具调用示例

```json
// 创建文档
mcp__lark-mcp__docx_builtin_import({
  "data": { "file_name": "标题", "markdown": "内容" }
})

// 添加协作者
mcp__lark-mcp__drive_v1_permissionMember_create({
  "path": { "token": "文档token" },
  "params": { "type": "docx" },
  "data": { "member_type": "email", "member_id": "xxx@gaowei.com", "perm": "full_access", "type": "user" }
})
```

