function readFileSync(filePath) {
  if (!fs.existsSync(filePath)) {
    throw new Error(`文件不存在: ${filePath}`);
  }
  return fs.readFileSync(filePath, 'utf-8');
}

// ==================== API 调用（支持多模型）====================

function callAPI(prompt, model) {
  return new Promise((resolve, reject) => {
    // GPT-5.x 系列需要使用 max_completion_tokens 而不是 max_tokens
    const isGPT5 = model.startsWith('gpt-5');
    const maxTokensKey = isGPT5 ? 'max_completion_tokens' : 'max_tokens';

    const payload = {
      model: model,
      messages: [{ role: 'user', content: prompt }],
      [maxTokensKey]: CONFIG.api.maxTokens
    };

    // 注意：代理服务暂不支持 thinking 参数

    const url = new URL(CONFIG.api.baseUrl + '/v1/chat/completions');

    const reqOptions = {
      hostname: url.hostname,
      port: url.port || 443,
      path: url.pathname,
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${CONFIG.api.apiKey}`
      }
    };

    log(`调用 API (${model})...`);

    const req = https.request(reqOptions, (res) => {
      let data = '';
      res.on('data', chunk => data += chunk);
      res.on('end', () => {
        try {
          const json = JSON.parse(data);
          if (json.error) {
            reject(new Error(`API错误: ${json.error.message || JSON.stringify(json.error)}`));
          } else if (json.choices && json.choices[0]) {
            log('API 调用成功');
            resolve(json.choices[0].message.content);
          } else {
            reject(new Error('意外的响应格式: ' + data.slice(0, 200)));
          }
        } catch (e) {
          reject(new Error('解析响应失败: ' + e.message));
        }
      });
    });

    req.on('error', reject);
    req.write(JSON.stringify(payload));
    req.end();
  });
}

