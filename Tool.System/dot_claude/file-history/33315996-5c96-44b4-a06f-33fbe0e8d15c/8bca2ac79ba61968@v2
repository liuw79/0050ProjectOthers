// ==================== 格式转换：HTML → Markdown ====================

/**
 * 将 HTML 格式的报告转换为 Markdown 格式
 * 专门处理 AI 教练评估报告的结构
 */
function htmlToMarkdown(html) {
  let md = html;

  // 1. 提取 HTML 内容（去除可能的 markdown 代码块）
  const htmlMatch = html.match(/```html\s*([\s\S]*?)```/);
  if (htmlMatch) {
    md = htmlMatch[1].trim();
  }

  // 2. 移除 <style> 标签及其内容
  md = md.replace(/<style[^>]*>[\s\S]*?<\/style>/gi, '');

  // 3. 移除所有 HTML 注释
  md = md.replace(/<!--[\s\S]*?-->/g, '');

  // 4. 处理标题
  md = md.replace(/<h1[^>]*>(.*?)<\/h1>/gi, '# $1\n\n');
  md = md.replace(/<h2[^>]*>(.*?)<\/h2>/gi, '## $1\n\n');
  md = md.replace(/<h3[^>]*>(.*?)<\/h3>/gi, '### $1\n\n');
  md = md.replace(/<h4[^>]*>(.*?)<\/h4>/gi, '#### $1\n\n');

  // 5. 处理段落和换行
  md = md.replace(/<br\s*\/?>/gi, '\n');
  md = md.replace(/<p[^>]*>(.*?)<\/p>/gis, '$1\n\n');

  // 6. 处理加粗和斜体
  md = md.replace(/<strong[^>]*>(.*?)<\/strong>/gi, '**$1**');
  md = md.replace(/<b[^>]*>(.*?)<\/b>/gi, '**$1**');
  md = md.replace(/<em[^>]*>(.*?)<\/em>/gi, '*$1*');
  md = md.replace(/<i[^>]*>(.*?)<\/i>/gi, '*$1*');

  // 7. 处理链接
  md = md.replace(/<a[^>]*href="([^"]*)"[^>]*>(.*?)<\/a>/gi, '[$2]($1)');

  // 8. 处理列表
  md = md.replace(/<ul[^>]*>/gi, '');
  md = md.replace(/<\/ul>/gi, '\n');
  md = md.replace(/<ol[^>]*>/gi, '');
  md = md.replace(/<\/ol>/gi, '\n');
  md = md.replace(/<li[^>]*>(.*?)<\/li>/gi, '- $1\n');

  // 9. 处理 div - 将带 class 的 div 转为引用块或保留内容
  md = md.replace(/<div[^>]*class="[^"]*score[^"]*"[^>]*>(.*?)<\/div>/gis, '> **得分: **$1\n\n');
  md = md.replace(/<div[^>]*>(.*?)<\/div>/gis, '$1\n');

  // 10. 处理 span - 只保留内容
  md = md.replace(/<span[^>]*>(.*?)<\/span>/gi, '$1');

  // 11. 处理表格（简单处理）
  md = md.replace(/<table[^>]*>/gi, '\n');
  md = md.replace(/<\/table>/gi, '\n');
  md = md.replace(/<tr[^>]*>/gi, '| ');
  md = md.replace(/<\/tr>/gi, ' |\n');
  md = md.replace(/<th[^>]*>(.*?)<\/th>/gi, ' $1 |');
  md = md.replace(/<td[^>]*>(.*?)<\/td>/gi, ' $1 |');
  md = md.replace(/<thead[^>]*>[\s\S]*?<\/thead>/gi, '');
  md = md.replace(/<tbody[^>]*>/gi, '');
  md = md.replace(/<\/tbody>/gi, '');

  // 12. 处理 hr 分隔线
  md = md.replace(/<hr\s*\/?>/gi, '\n---\n');

  // 13. 处理引用块
  md = md.replace(/<blockquote[^>]*>(.*?)<\/blockquote>/gis, '> $1\n\n');

  // 14. 移除所有剩余的 HTML 标签
  md = md.replace(/<[^>]+>/g, '');

  // 15. 清理多余空行（保留最多2个连续空行）
  md = md.replace(/\n{3,}/g, '\n\n');

  // 16. 清理行首行尾空白
  md = md.split('\n').map(line => line.trim()).join('\n');

  // 17. 添加报告头部（飞书文档格式）
  const header = `# 班主任AI教练评估报告

> 本报告由 AI 教练系统自动生成

---

`;

  return header + md.trim();
}

