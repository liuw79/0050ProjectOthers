// ==================== Markdown 转 HTML ====================

function markdownToHtml(md) {
  let html = md;

  // 移除 YAML frontmatter
  html = html.replace(/^---[\s\S]*?---\n*/, '');

  // 移除文档标题（已在 header 中显示）
  html = html.replace(/^# 班主任AI教练评估报告\n*/i, '');
  html = html.replace(/^> 本报告由.*?\n\n?/s, '');
  html = html.replace(/^---\n*/, '');

  // 处理标题
  html = html.replace(/^#### (.*?)$/gm, '<h4>$1</h4>');
  html = html.replace(/^### (.*?)$/gm, '<h3>$1</h3>');
  html = html.replace(/^## (.*?)$/gm, '<h2>$1</h2>');
  html = html.replace(/^# (.*?)$/gm, '<h1>$1</h1>');

  // 处理分数显示 (如 **85分** → 特殊样式)
  html = html.replace(/\*\*(\d{1,3})分?\*\*/g, '<span class="score-box">$1分</span>');

  // 处理加粗和斜体
  html = html.replace(/\*\*\*(.*?)\*\*\*/g, '<strong><em>$1</em></strong>');
  html = html.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
  html = html.replace(/\*(.*?)\*/g, '<em>$1</em>');

  // 处理引用块
  html = html.replace(/^&gt; (.*?)$/gm, '<blockquote><p>$1</p></blockquote>');
  // 合并连续的引用块
  html = html.replace(/<\/blockquote>\n<blockquote>/g, '\n');

  // 处理无序列表
  html = html.replace(/^- (.*?)$/gm, '<li>$1</li>');
  html = html.replace(/(<li>.*<\/li>\n?)+/g, '<ul>$&</ul>');

  // 处理有序列表
  html = html.replace(/^\d+\. (.*?)$/gm, '<li>$1</li>');
  // 注意：有序列表也可能被上面的无序列表处理覆盖，这里简化处理

  // 处理行内代码
  html = html.replace(/`([^`]+)`/g, '<code>$1</code>');

  // 处理代码块
  html = html.replace(/```(\w*)\n([\s\S]*?)```/g, '<pre><code>$2</code></pre>');

  // 处理水平线
  html = html.replace(/^---$/gm, '<hr>');

  // 处理表格（简化处理）
  html = html.replace(/^\| (.*) \|$/gm, function(match, content) {
    const cells = content.split(' | ').map(c => c.trim());
    const isHeader = cells.every(c => /^[-:]+$/.test(c));
    if (isHeader) return ''; // 跳过分隔行

    const cellTag = 'td';
    return '<tr>' + cells.map(c => `<${cellTag}>${c}</${cellTag}>`).join('') + '</tr>\n';
  });

  // 包装表格
  html = html.replace(/(<tr>.*<\/tr>\n?)+/g, '<table>$&</table>');

  // 处理段落（不在其他标签中的文本）
  html = html.split('\n\n').map(para => {
    para = para.trim();
    if (!para) return '';
    // 如果已经是 HTML 块级元素，不再包装
    if (/^<(h[1-4]|ul|ol|li|blockquote|pre|table|hr|div|p)/.test(para)) {
      return para;
    }
    // 如果以 HTML 块级元素结尾
    if (/<\/(h[1-4]|ul|ol|li|blockquote|pre|table|div|p)>$/.test(para)) {
      return para;
    }
    return `<p>${para.replace(/\n/g, '<br>')}</p>`;
  }).join('\n');

  // 清理多余空行
  html = html.replace(/\n{3,}/g, '\n\n');

  return html;
}

// ==================== 主函数 ====================

function main() {
  const args = process.argv.slice(2);

  if (args.length === 0) {
    console.log(`
Markdown 转 HTML 转换器

用法：
  node md2html.js input.md [output.html]
  node md2html.js input.md  # 输出到 input.html

参数：
  input.md    输入的 Markdown 文件
  output.html 输出的 HTML 文件（可选，默认同名）
`);
    process.exit(0);
  }

  const inputPath = args[0];
  let outputPath = args[1];

  if (!fs.existsSync(inputPath)) {
    console.error(`❌ 文件不存在: ${inputPath}`);
    process.exit(1);
  }

  // 默认输出路径
  if (!outputPath) {
    outputPath = inputPath.replace(/\.md$/i, '.html');
  }

  // 读取 MD 文件
  const mdContent = fs.readFileSync(inputPath, 'utf-8');

  // 转换
  const htmlContent = markdownToHtml(mdContent);

  // 填充模板
  const finalHtml = HTML_TEMPLATE.replace('{{CONTENT}}', htmlContent);

  // 写入 HTML 文件
  fs.writeFileSync(outputPath, finalHtml, 'utf-8');

  console.log(`✅ 转换完成`);
  console.log(`   输入: ${inputPath}`);
  console.log(`   输出: ${outputPath}`);
}

main();
