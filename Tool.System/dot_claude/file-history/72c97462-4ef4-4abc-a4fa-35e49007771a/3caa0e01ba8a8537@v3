<script setup lang="ts">
import { computed } from 'vue'
import type { H5CourseDetail } from '@/types/h5'

interface Props {
  course: H5CourseDetail
}

const props = defineProps<Props>()

// 将描述文本按段落分割
const descriptionParagraphs = computed(() => {
  if (!props.course.description) return []
  return props.course.description
    .split('\n\n')
    .map(p => p.trim())
    .filter(p => p.length > 0)
})
</script>

<template>
  <div class="h5-section" id="intro">
    <div class="h5-section-header">
      <h2 class="h5-section-title">课程介绍</h2>
    </div>
    <div class="h5-section-content">
      <!-- 课程描述 - 多段落渲染 -->
      <div class="h5-intro-desc">
        <p v-for="(para, index) in descriptionParagraphs" :key="index" class="h5-intro-paragraph">
          {{ para }}
        </p>
      </div>

      <!-- 课程标签 -->
      <div v-if="course.tags?.length" class="h5-intro-tags">
        <span v-for="tag in course.tags" :key="tag" class="h5-tag h5-tag-primary">
          {{ tag }}
        </span>
      </div>

      <!-- 课程亮点 -->
      <div v-if="course.highlights?.length" class="h5-intro-highlights">
        <h3 class="h5-intro-subtitle">课程亮点</h3>
        <div class="h5-module-list">
          <div v-for="(highlight, index) in course.highlights" :key="index" class="h5-highlight-item">
            <div class="h5-highlight-icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20 6 9 17 4 12" />
              </svg>
            </div>
            <span class="h5-highlight-text">{{ highlight }}</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

