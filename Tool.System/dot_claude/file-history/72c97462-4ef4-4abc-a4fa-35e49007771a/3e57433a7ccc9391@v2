## 常见修改场景

### 场景1: 替换图片

```javascript
// 1. 先用 Read 工具上传图片获取 CDN URL
// 2. 然后更新 HTML
await page.evaluate(() => {
  const textarea = document.querySelector('textarea');
  let html = textarea.value;
  html = html.replace(/旧图片URL/g, '新CDN_URL');
  textarea.value = html;
});
```

### 场景2: 修改 CSS 样式

```javascript
await page.evaluate(() => {
  const textarea = document.querySelector('textarea');
  let html = textarea.value;

  // 修改类样式
  html = html.replace(
    /\.gw-h5-hero-logo {[^}]+}/,
    `.gw-h5-hero-logo { position: absolute; top: 16px; right: 16px; height: 28px; }`
  );

  textarea.value = html;
});
```

### 场景3: 批量修改多个元素

```javascript
await page.evaluate(() => {
  const textarea = document.querySelector('textarea');
  let html = textarea.value;

  // 多个替换
  const replacements = [
    { from: /pattern1/g, to: 'replacement1' },
    { from: /pattern2/g, to: 'replacement2' },
    { from: /pattern3/g, to: 'replacement3' }
  ];

  replacements.forEach(({ from, to }) => {
    html = html.replace(from, to);
  });

  textarea.value = html;
});
```

