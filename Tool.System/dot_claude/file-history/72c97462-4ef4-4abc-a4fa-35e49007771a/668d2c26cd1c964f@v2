<script setup lang="ts">
import { ref } from 'vue'

interface Props {
  price?: number
  priceUnit?: string
  enrolledCount?: number
}

withDefaults(defineProps<Props>(), {
  price: 0,
  priceUnit: '人',
  enrolledCount: 0
})

const emit = defineEmits<{
  home: []
  follow: []
  enroll: []
}>()

const isFollowing = ref(false)

// 首页
const goHome = () => {
  emit('home')
}

// 关注/取消关注
const toggleFollow = () => {
  isFollowing.value = !isFollowing.value
  emit('follow')
}

// 立即报名
const handleEnroll = () => {
  emit('enroll')
}

// 格式化价格
const formatPrice = (price: number) => {
  if (price === 0) return '咨询'
  return price.toLocaleString()
}
</script>

<template>
  <div class="h5-bottom-bar">
    <!-- 左侧操作区 -->
    <div class="h5-bottom-bar-left">
      <!-- 首页 -->
      <button class="h5-bottom-bar-action" @click="goHome">
        <span class="h5-bottom-bar-action-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            <polyline points="9 22 9 12 15 12 15 22" />
          </svg>
        </span>
        <span>首页</span>
      </button>

      <!-- 关注 -->
      <button class="h5-bottom-bar-action" @click="toggleFollow">
        <span class="h5-bottom-bar-action-icon" :class="{ 'is-active': isFollowing }">
          <svg v-if="!isFollowing" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
          </svg>
          <svg v-else width="22" height="22" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2">
            <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" />
          </svg>
        </span>
        <span>{{ isFollowing ? '已关注' : '关注' }}</span>
      </button>
    </div>

    <!-- 右侧价格和报名按钮 -->
    <div class="h5-bottom-bar-main">
      <!-- 价格信息 -->
      <div class="h5-bottom-bar-price">
        <span class="h5-price-symbol">¥</span>
        <span class="h5-price-value">{{ formatPrice(price) }}</span>
        <span v-if="price > 0" class="h5-price-unit">/{{ priceUnit }}</span>
      </div>

      <!-- 报名按钮 -->
      <button class="h5-bottom-bar-btn h5-btn-accent" @click="handleEnroll">
        立即报名
      </button>
    </div>
  </div>
</template>

