## 完整执行脚本示例

```javascript
// GW.Content/server/scripts/coach-evaluate.js

import { ai } from '../src/lib/ai.js';
import nodemailer from 'nodemailer';
import fs from 'fs';
import path from 'path';

// 配置
const COURSE_NAME = process.argv[2];
const TEACHER_NAME = process.argv[3];
const DATE_FOLDER = process.argv[4] || new Date().toISOString().slice(0,10).replace(/-/g, '');

const BASE_DIR = '/Users/comdir/SynologyDrive/0050Project/GW.Content';
const SCENE_DIR = `${BASE_DIR}/五句话介绍/现场/${DATE_FOLDER}/${COURSE_NAME} ${TEACHER_NAME}`;

// Step 1: 读取素材
const transcript = fs.readFileSync(`${SCENE_DIR}/录音稿.txt`, 'utf-8');
const gaowei5 = fs.readFileSync(`${BASE_DIR}/五句话介绍/高维学堂5句话介绍.md`, 'utf-8');
const course5 = fs.readFileSync(`${BASE_DIR}/五句话介绍/${COURSE_NAME}-主持词.md`, 'utf-8');
const promptTemplate = fs.readFileSync(`${BASE_DIR}/五句话介绍/班主任AI教练 2026年03月11日V3（高阶加分版）.md`, 'utf-8');

// Step 2: 组装 Prompt
const fullPrompt = promptTemplate
  .replace('[在此处填写课程名称]', COURSE_NAME)
  .replace('[在此处粘贴录音文字]', transcript);

// Step 3: 调用 Gemini
console.log('正在生成评估报告...');
const htmlReport = await ai.generate(fullPrompt, {
  model: 'gemini-3.1-pro-preview',
  maxTokens: 16384
});

// Step 4: 发送邮件
console.log('正在发送邮件...');
const transporter = nodemailer.createTransport({
  host: 'smtp.feishu.cn',
  port: 465,
  secure: true,
  auth: {
    user: 'liuwei@gaowei.com',
    pass: 'AQg6ve0Xpdb3FG87'
  }
});

await transporter.sendMail({
  from: '"高维学堂AI教练" <liuwei@gaowei.com>',
  to: 'lw@gaowei.com, cbr@gaowei.com',
  subject: `${COURSE_NAME} ${TEACHER_NAME} AI教练评估报告 - ${new Date().toLocaleDateString('zh-CN')}`,
  html: htmlReport
});

// Step 5: 本地存档
const reportPath = `${SCENE_DIR}/${TEACHER_NAME}-AI教练报告.html`;
fs.writeFileSync(reportPath, htmlReport);
console.log(`报告已保存: ${reportPath}`);

console.log('完成！');
```

