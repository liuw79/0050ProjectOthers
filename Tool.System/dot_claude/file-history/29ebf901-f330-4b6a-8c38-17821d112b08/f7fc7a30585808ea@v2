// 辰辰 GTM 课程评估脚本
import { ai } from '../src/lib/ai.js';
import fs from 'fs';

const BASE_DIR = '/Users/comdir/SynologyDrive/0050Project/GW.Content';

// 读取素材
const transcript = fs.readFileSync(`${BASE_DIR}/五句话介绍/现场/20260307/GTM产品市场协同作战 辰辰/gtm01_原文.txt`, 'utf-8');
const gaowei5 = fs.readFileSync(`${BASE_DIR}/五句话介绍/高维学堂5句话介绍.md`, 'utf-8');
const course5 = fs.readFileSync(`${BASE_DIR}/五句话介绍/GTM产品市场协同作战-主持词.md`, 'utf-8');
const promptTemplate = fs.readFileSync(`${BASE_DIR}/五句话介绍/班主任AI教练 2026年03月11日V3（高阶加分版）.md`, 'utf-8');

// 组装完整 Prompt
const fullPrompt = `
${promptTemplate}

---

# 实际输入数据

**Target Course**: GTM产品市场协同作战

**Transcript**:
${transcript}

**File Paths**:
*   高维学堂5句话: \`${BASE_DIR}/五句话介绍/高维学堂5句话介绍.md\`
*   课程5句话: \`${BASE_DIR}/五句话介绍/GTM产品市场协同作战-主持词.md\`

**标准参考素材**:

## 高维学堂5句话介绍
${gaowei5}

## GTM产品市场协同作战 主持词（标准稿）
${course5}
`;

console.log('正在生成评估报告...');
console.log('Prompt 长度:', fullPrompt.length, '字符');

const htmlReport = await ai.generate(fullPrompt, {
  model: 'gemini-3.1-pro-preview',
  maxTokens: 16384
});

console.log('生成完成，报告长度:', htmlReport.length, '字符');

// 保存报告
const reportPath = `${BASE_DIR}/五句话介绍/现场/20260307/GTM产品市场协同作战 辰辰/辰辰-AI教练报告.html`;
fs.writeFileSync(reportPath, htmlReport);
console.log('报告已保存:', reportPath);

// 保存 Prompt 用于调试
const promptPath = `${BASE_DIR}/五句话介绍/现场/20260307/GTM产品市场协同作战 辰辰/debug-prompt.txt`;
fs.writeFileSync(promptPath, fullPrompt);
console.log('Prompt 已保存:', promptPath);

console.log('\n--- 报告内容预览 (前3000字符) ---\n');
