  .card-header {
    display: flex;
    align-items: center;
    margin-bottom: 12px;
  }
  .card-title {
    font-weight: 700;
    font-size: 16px;
    color: #2d3748;
  }
  .tag {
    font-size: 12px;
    color: #fff;
    padding: 3px 10px;
    border-radius: 12px;
    margin-left: 12px;
