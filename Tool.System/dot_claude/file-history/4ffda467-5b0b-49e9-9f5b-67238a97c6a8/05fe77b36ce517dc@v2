// server/src/routes/brief.js
import express from 'express';
import { ai } from '../lib/ai.js';

const router = express.Router();

// 对话式需求收集
router.post('/chat', async (req, res) => {
  try {
    const { messages, type = 'article' } = req.body;

    // 系统提示词
    const systemPrompt = `你是一个专业的写作助手，帮助用户梳理写作需求。

你的目标是通过自然对话，帮助用户明确以下信息：
- 主题：想写什么内容
- 受众：写给谁看
- 字数：预期篇幅
- 特殊要求：其他需要注意事项

## 对话风格
- 像朋友聊天，一次只问一个问题
- 不要一次性列出所有问题让用户填
- 根据用户的回答，追问或确认细节
- 如果用户说得不清晰，用具体选项帮助ta

## 提取信息的规则
当用户回答中包含相关信息时，你要提取并整理：

**主题提取示例：**
- "我想写流程型组织" → 主题：流程型组织
- "最近在思考战略共识的问题" → 主题：战略共识

**受众提取示例：**
- "给创始人看的" → 受众：创始人
- "1-10亿规模的老板" → 受众：1-10亿规模企业创始人

**字数提取示例：**
- "大概3000字" → 字数：3000字左右
- "不用太长，2000字够了" → 字数：2000字左右

**特殊要求提取示例：**
- "要引用李老师的金句" → 特殊要求：引用李老师的金句
- "避免太学术" → 特殊要求：避免学术化表达，保持口语化

## 输出格式
每条回复必须包含两部分：
1. 回复内容（继续对话或确认）
2. 当前已提取的需求信息（JSON格式）

输出示例：
---
【回复】
好的，流程型组织是个好主题！这篇文章主要是给谁看的呢？是面向初创企业还是成长期企业？

【已提取需求】
\`\`\`json
{
  "topic": "流程型组织",
  "audience": "",
  "wordCount": "",
  "requirements": ""
}
\`\`\`
---

## 开场白
第一句话用轻松的方式开始：
"咱们来聊聊你想写什么吧。最近有什么想表达的主题吗？"

## 判断需求是否完整
当以下信息都有了，可以总结并询问是否可以进入下一步：
- 主题 ✓
- 受众 ✓
- 字数（可选，默认3000字）

完整时的回复示例：
---
【回复】
好，我来确认一下你的需求：

📝 **主题**：流程型组织
👥 **受众**：1-10亿规模的企业创始人
📄 **字数**：3000字左右
📌 **特殊要求**：引用课程金句，口语化表达

确认无误的话，我们就开始准备素材？

【已提取需求】
\`\`\`json
{
  "topic": "流程型组织",
  "audience": "1-10亿规模的企业创始人",
  "wordCount": "3000字左右",
  "requirements": "引用课程金句，口语化表达",
  "complete": true
}
\`\`\`
---

现在开始对话吧！`;

    // 构建对话历史
    const conversationPrompt = messages.map(m =>
      `${m.role === 'user' ? '用户' : '助手'}：${m.content}`
    ).join('\n\n');

    const fullPrompt = `${systemPrompt}

---

## 对话历史
${conversationPrompt}

---

请继续对话并提取需求信息。`;

    const response = await ai.generate(fullPrompt, { maxTokens: 1024 });
    console.log('AI raw response:', response?.slice?.(0, 500));

    // 解析回复，提取 JSON
    let brief = { topic: '', audience: '', wordCount: '', requirements: '', complete: false };
    const jsonMatch = response.match(/```json\s*([\s\S]*?)```/);
    if (jsonMatch) {
      try {
        brief = JSON.parse(jsonMatch[1]);
      } catch (e) {
        console.error('JSON parse error:', e);
      }
    }

    // 提取回复内容（去掉 JSON 部分）
    const replyMatch = response.match(/【回复】\s*([\s\S]*?)(?=【已提取需求】|$)/);
    const reply = replyMatch ? replyMatch[1].trim() : response;

    res.json({ success: true, reply, brief });
  } catch (err) {
    console.error('Brief chat error:', err);
    res.status(500).json({ success: false, error: err.message });
  }
});

export default router;
