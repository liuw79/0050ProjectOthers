def get_tenant_token():
    """获取tenant_access_token"""
    url = "https://open.feishu.cn/open-apis/auth/v3/tenant_access_token/internal"
    data = {
        "app_id": APP_ID,
        "app_secret": APP_SECRET
    }
    resp = requests.post(url, json=data)
    result = resp.json()
    if result.get("code") == 0:
        return result["tenant_access_token"]
    else:
        print(f"获取token失败: {result}")
        return None

def set_permission(token, doc_token, name):
    """设置文档权限 - 让组织内所有人可查看"""
    url = f"https://open.feishu.cn/open-apis/drive/v1/permissions/{doc_token}/members"
    headers = {
        "Authorization": f"Bearer {token}",
        "Content-Type": "application/json"
    }

    # 尝试设置组织内所有人可查看
    data = {
        "member_type": "userid",
        "member_id": "all",  # 组织内所有人
        "perm": "view"
    }

    print(f"\n尝试为 {name} 设置权限...")

    # 方法1: 使用permissions API
    resp = requests.post(url, headers=headers, json=data)
    result = resp.json()
    print(f"  方法1结果: {result}")

    # 如果失败，尝试方法2: 使用permissionMember_create
    if result.get("code") != 0:
        url2 = f"https://open.feishu.cn/open-apis/drive/v1/permissionMembers?token={doc_token}&type=docx"
        data2 = {
            "member_type": "openid",
            "member_id": "ou_xxxxx",  # 需要用户的open_id
            "perm": "view"
        }
        resp2 = requests.post(url2, headers=headers, json=data2)
        result2 = resp2.json()
        print(f"  方法2结果: {result2}")

    return result

