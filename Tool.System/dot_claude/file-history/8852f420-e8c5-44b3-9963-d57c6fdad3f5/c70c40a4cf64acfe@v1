## 参考代码：Markdown解析器

**这是经过验证的解析器，遵循所有规则**：

```python
import re

# 专有名词校准列表见：04_System/publish_index.md
CORRECTIONS = {"蓝河": "蓝禾", "小野禾子": "小野和子"}

def correct_content(content):
    for wrong, correct in CORRECTIONS.items():
        content = content.replace(wrong, correct)
    return content

def normalize_title(title):
    return title.replace("：", "_").replace(":", "_")

def parse_inline_format(text):
    """解析行内格式，支持**加粗**"""
    elements = []
    pattern = r'\*\*([^*]+)\*\*'
    last_end = 0

    for match in re.finditer(pattern, text):
        if match.start() > last_end:
            plain = text[last_end:match.start()]
            if plain:
                elements.append({"text_run": {"content": plain, "text_element_style": {}}})
        elements.append({"text_run": {"content": match.group(1), "text_element_style": {"bold": True}}})
        last_end = match.end()

    if last_end < len(text):
        remaining = text[last_end:]
        if remaining:
            elements.append({"text_run": {"content": remaining, "text_element_style": {}}})

    return elements if elements else [{"text_run": {"content": text, "text_element_style": {}}}]

def text_width(s):
    """计算文本宽度（中文2，英文1）"""
    return sum(2 if '\u4e00' <= c <= '\u9fff' else 1 for c in s)

def format_table(data):
    """格式化表格为文本格式，处理<br>换行"""
    if not data:
        return []

    cols = max(len(r) for r in data)
    # 计算每列最大宽度（考虑<br>换行）
    widths = []
    for i in range(cols):
        max_w = 0
        for row in data:
            if i < len(row):
                cell_lines = row[i].split('<br>')
                max_w = max(max_w, max(text_width(l) for l in cell_lines))
        widths.append(max_w)

    result = []
    for row in data:
        # 每个单元格按<br>分割
        lines_per_cell = [c.split('<br>') for c in row]
        max_lines = max(len(l) for l in lines_per_cell)

        for line_idx in range(max_lines):
            cells = []
            for col_idx in range(cols):
                if col_idx < len(row):
                    cell_lines = row[col_idx].split('<br>')
                    text = cell_lines[line_idx] if line_idx < len(cell_lines) else ''
                    # 补齐宽度
                    padding = ' ' * (widths[col_idx] - text_width(text))
                    cells.append(text + padding)
                else:
                    cells.append(' ' * widths[col_idx])
            result.append('│ ' + ' │ '.join(cells) + ' │')

    return result

def parse_markdown(content):
    """Markdown解析为飞书blocks - 遵循核心规则"""
    blocks = []
    lines = content.split('\n')
    in_table = False
    table_data = []

    for line in lines:
        stripped = line.strip()

        # 空行：结束表格
        if not stripped:
            if in_table and table_data:
                for row_text in format_table(table_data):
                    elements = parse_inline_format(row_text)
                    blocks.append({"block_type": 2, "text": {"elements": elements}})
                table_data = []
                in_table = False
            continue

        # 分隔线
        if stripped == '---':
            blocks.append({"block_type": 2, "text": {"elements": [{"text_run": {"content": "─" * 40}}]}})
            continue

        # 表格（使用文本格式）
        if stripped.startswith('|') and '|' in stripped[1:]:
            in_table = True
            cells = [c.strip() for c in stripped.split('|')[1:-1]]
            # 跳过分隔行 |---|---|
            if not all(set(c) <= set('-:| ') for c in cells):
                table_data.append(cells)
            continue

        # 标题（heading block可用）
        if stripped.startswith('### '):
            elements = parse_inline_format(stripped[4:])
            blocks.append({"block_type": 5, "heading3": {"elements": elements}})
        elif stripped.startswith('## '):
            elements = parse_inline_format(stripped[3:])
            blocks.append({"block_type": 4, "heading2": {"elements": elements}})
        elif stripped.startswith('# '):
            elements = parse_inline_format(stripped[2:])
            blocks.append({"block_type": 3, "heading1": {"elements": elements}})

        # 引用（quote block可用）
        elif stripped.startswith('> '):
            elements = parse_inline_format(stripped[2:])
            blocks.append({"block_type": 15, "quote": {"elements": elements}})

        # 无序列表 → 转文本（禁用bullet block）
        elif stripped.startswith('- ') or stripped.startswith('* '):
            elements = parse_inline_format('• ' + stripped[2:])
            blocks.append({"block_type": 2, "text": {"elements": elements}})

        # 有序列表 → 转文本（禁用ordered block）
        elif re.match(r'^\d+\.\s', stripped):
            elements = parse_inline_format(stripped)
            blocks.append({"block_type": 2, "text": {"elements": elements}})

        # 普通文本
        else:
            elements = parse_inline_format(stripped)
            blocks.append({"block_type": 2, "text": {"elements": elements}})

    # 处理未结束的表格
    if table_data:
        for row_text in format_table(table_data):
            elements = parse_inline_format(row_text)
            blocks.append({"block_type": 2, "text": {"elements": elements}})

    return blocks
```

