### 代码示例：创建父子节点

```python
def create_wiki_doc(title, parent_token=None):
    """创建wiki节点，可指定父节点"""
    url = f"https://open.feishu.cn/open-apis/wiki/v2/spaces/{SPACE_ID}/nodes"
    data = {
        "node_type": "origin",
        "obj_type": "docx",
        "title": title
    }
    if parent_token:
        data["parent_node_token"] = parent_token
    resp = requests.post(url, headers=HEADERS, json=data)
    result = resp.json()
    if result.get("code") == 0:
        return result["data"]["node"]["obj_token"], result["data"]["node"]["node_token"]
    return None, None

def main():
    # 1. 创建父节点（带版本号）
    obj_token, parent_token = create_wiki_doc("07_组织建设_V1.01")
    if not parent_token:
        print("创建目录失败！")
        return

    # 2. 发布文档到父节点下（文档名不加版本号）
    files = ["人才画像_项目成功经理.md", "人才画像_企业陪跑顾问.md", ...]
    for file_path in files:
        title = os.path.basename(file_path).replace('.md', '')
        publish_file(file_path, parent_token)  # 使用parent_token作为父节点
```

