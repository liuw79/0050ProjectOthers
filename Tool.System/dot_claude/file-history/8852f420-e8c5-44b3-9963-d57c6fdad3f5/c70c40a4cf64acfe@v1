def update_homepage(user_token, homepage_token, new_blocks):
    """更新知识库首页（删除旧内容，写入新内容）"""

    # 1. 获取当前所有blocks
    url = f"https://open.feishu.cn/open-apis/docx/v1/documents/{homepage_token}/blocks/{homepage_token}/children"
    resp = requests.get(url, headers=headers)
    result = resp.json()

    if result.get("code") == 0:
        children = result["data"]["items"]

        # 2. 删除所有子blocks
        indices = list(range(len(children)))
        delete_url = f"{url}/batch_delete"
        requests.delete(delete_url, headers=headers, json={"indices": indices})

    # 3. 写入新内容
    for batch in chunks(new_blocks, 50):
        requests.post(url, headers=headers, json={"children": batch})
        time.sleep(0.3)

