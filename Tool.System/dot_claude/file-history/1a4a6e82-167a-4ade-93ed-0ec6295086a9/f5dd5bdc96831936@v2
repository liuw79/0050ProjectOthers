def create_wiki_node(title, parent_token=None):
    """创建Wiki节点"""
    url = f"https://open.feishu.cn/open-apis/wiki/v2/spaces/{SPACE_ID}/nodes"
    data = {
        "node_type": "origin",
        "obj_type": "docx",
        "title": title
    }
    if parent_token:
        data["parent_node_token"] = parent_token

    resp = requests.post(url, headers=HEADERS, json=data, timeout=30)

    try:
        result = resp.json()
    except:
        print(f"  ❌ JSON解析失败，响应: {resp.text[:200]}")
        return None, None

    if result.get("code") == 0:
        node = result["data"]["node"]
        return node["obj_token"], node["node_token"]
    else:
        print(f"  ❌ 创建节点失败: {result.get('msg', str(result))}")
        return None, None

def parse_inline_format(text):
    """解析行内格式"""
    elements = []
    # 处理加粗
    parts = re.split(r'(\*\*[^*]+\*\*)', text)

    for part in parts:
        if part.startswith('**') and part.endswith('**'):
            elements.append({
                "text_run": {
                    "content": part[2:-2],
                    "text_element_style": {"bold": True}
                }
            })
        elif part:
            elements.append({
                "text_run": {
                    "content": part,
                    "text_element_style": {}
                }
            })

    return elements if elements else [{"text_run": {"content": text, "text_element_style": {}}}]

def parse_markdown_to_blocks(content):
    """将Markdown解析为飞书blocks"""
    blocks = []
    lines = content.split('\n')

    for line in lines:
        stripped = line.strip()
        if not stripped:
            continue

        # 标题处理
        if stripped.startswith('### '):
            elements = parse_inline_format(stripped[4:])
            blocks.append({"block_type": 5, "heading3": {"elements": elements}})
        elif stripped.startswith('## '):
            elements = parse_inline_format(stripped[3:])
            blocks.append({"block_type": 4, "heading2": {"elements": elements}})
        elif stripped.startswith('# '):
            elements = parse_inline_format(stripped[2:])
            blocks.append({"block_type": 3, "heading1": {"elements": elements}})
        elif stripped.startswith('> '):
            elements = parse_inline_format(stripped[2:])
            blocks.append({"block_type": 15, "quote": {"elements": elements}})
        elif stripped.startswith('- ') or stripped.startswith('* '):
            elements = parse_inline_format('• ' + stripped[2:])
            blocks.append({"block_type": 2, "text": {"elements": elements}})
        elif stripped == '---':
            blocks.append({
                "block_type": 2,
                "text": {"elements": [{"text_run": {"content": "─" * 40}}]}
            })
        else:
            elements = parse_inline_format(stripped)
            blocks.append({"block_type": 2, "text": {"elements": elements}})

    return blocks

def write_document_content(obj_token, blocks):
    """写入文档内容"""
    url = f"https://open.feishu.cn/open-apis/docx/v1/documents/{obj_token}/blocks/{obj_token}/children/batch_create"

    # 分批写入（每批50个）
    success_count = 0
    for i in range(0, len(blocks), 50):
        batch = blocks[i:i+50]
        data = {
            "children": batch,
            "index": -1  # 追加到末尾
        }

        try:
            resp = requests.post(url, headers=HEADERS, json=data, timeout=30)
            result = resp.json()

            if result.get("code") == 0:
                success_count += len(batch)
            else:
                print(f"    ⚠️ 批次 {i//50 + 1} 失败: {result.get('msg', '')}")

        except Exception as e:
            print(f"    ⚠️ 批次 {i//50 + 1} 异常: {str(e)[:100]}")

        time.sleep(0.3)  # 频率限制

    return success_count, len(blocks)

