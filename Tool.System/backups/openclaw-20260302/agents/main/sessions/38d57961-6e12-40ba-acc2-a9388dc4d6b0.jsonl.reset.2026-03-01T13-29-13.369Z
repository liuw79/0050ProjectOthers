{"type":"message","id":"7e471582","parentId":"fa0dd688","timestamp":"2026-03-01T09:34:43.902Z","message":{"role":"toolResult","toolCallId":"call_761496a30be743009f5f37ea","toolName":"read","content":[{"type":"text","text":"import type { OpenClawPluginApi } from \"openclaw/plugin-sdk\";\nimport { emptyPluginConfigSchema } from \"openclaw/plugin-sdk\";\nimport { registerFeishuBitableTools } from \"./src/bitable.js\";\nimport { feishuPlugin } from \"./src/channel.js\";\nimport { registerFeishuCalendarTools } from \"./src/calendar.js\";\nimport { registerFeishuContactTools } from \"./src/contact.js\";\nimport { registerFeishuDocTools } from \"./src/docx.js\";\nimport { registerFeishuDriveTools } from \"./src/drive.js\";\nimport { registerFeishuPermTools } from \"./src/perm.js\";\nimport { setFeishuRuntime } from \"./src/runtime.js\";\nimport { registerFeishuWikiTools } from \"./src/wiki.js\";\n\nexport { monitorFeishuProvider } from \"./src/monitor.js\";\nexport {\n  sendMessageFeishu,\n  sendCardFeishu,\n  updateCardFeishu,\n  editMessageFeishu,\n  getMessageFeishu,\n} from \"./src/send.js\";\nexport {\n  uploadImageFeishu,\n  uploadFileFeishu,\n  sendImageFeishu,\n  sendFileFeishu,\n  sendMediaFeishu,\n} from \"./src/media.js\";\nexport { probeFeishu } from \"./src/probe.js\";\nexport {\n  addReactionFeishu,\n  removeReactionFeishu,\n  listReactionsFeishu,\n  FeishuEmoji,\n} from \"./src/reactions.js\";\nexport {\n  extractMentionTargets,\n  extractMessageBody,\n  isMentionForwardRequest,\n  formatMentionForText,\n  formatMentionForCard,\n  formatMentionAllForText,\n  formatMentionAllForCard,\n  buildMentionedMessage,\n  buildMentionedCardContent,\n  type MentionTarget,\n} from \"./src/mention.js\";\nexport { feishuPlugin } from \"./src/channel.js\";\n\nconst plugin = {\n  id: \"feishu\",\n  name: \"Feishu\",\n  description: \"Feishu/Lark channel plugin\",\n  configSchema: emptyPluginConfigSchema(),\n  register(api: OpenClawPluginApi) {\n    setFeishuRuntime(api.runtime);\n    api.registerChannel({ plugin: feishuPlugin });\n    registerFeishuDocTools(api);\n    registerFeishuWikiTools(api);\n    registerFeishuDriveTools(api);\n    registerFeishuPermTools(api);\n    registerFeishuBitableTools(api);\n    registerFeishuCalendarTools(api);\n    registerFeishuContactTools(api);\n  },\n};\n\nexport default plugin;\n"}],"isError":false,"timestamp":1772357683900}}
{"type":"message","id":"b24813e6","parentId":"7e471582","timestamp":"2026-03-01T09:34:46.753Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"call_73c3ad9e86aa4467a01bbba5","name":"read","arguments":{"file_path":"/Users/liuwei/openclaw/extensions/feishu/src/calendar.ts"}}],"api":"anthropic-messages","provider":"zai","model":"glm-5","usage":{"input":631,"output":25,"cacheRead":32576,"cacheWrite":0,"totalTokens":33232,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772357683902}}
{"type":"message","id":"47e2df5b","parentId":"b24813e6","timestamp":"2026-03-01T09:34:46.760Z","message":{"role":"toolResult","toolCallId":"call_73c3ad9e86aa4467a01bbba5","toolName":"read","content":[{"type":"text","text":"import type * as Lark from \"@larksuiteoapi/node-sdk\";\nimport type { OpenClawPluginApi } from \"openclaw/plugin-sdk\";\nimport { listEnabledFeishuAccounts } from \"./accounts.js\";\nimport { createFeishuClient } from \"./client.js\";\nimport { FeishuCalendarSchema } from \"./calendar-schema.js\";\nimport type { FeishuCalendarParams } from \"./calendar-schema.js\";\nimport { resolveToolsConfig } from \"./tools-config.js\";\n\nfunction json(data: unknown) {\n  return {\n    content: [{ type: \"text\" as const, text: JSON.stringify(data, null, 2) }],\n    details: data,\n  };\n}\n\n// Convert ISO time to Feishu timestamp (seconds)\nfunction toTimestamp(isoTime: string): number {\n  return Math.floor(new Date(isoTime).getTime() / 1000);\n}\n\n// Get the primary calendar ID by listing calendars\nasync function getPrimaryCalendarId(client: Lark.Client): Promise<string> {\n  try {\n    const resp: any = await client.calendar.calendar.list({\n      params: { page_size: 50 },\n    });\n\n    if (resp.code !== 0 || !resp.data?.calendar_list?.length) {\n      throw new Error(\"No calendars found\");\n    }\n\n    // Find primary calendar (usually the first one or marked as primary)\n    const primaryCal = resp.data.calendar_list.find(\n      (cal: any) => cal.primary === true || cal.type === \"primary\"\n    ) || resp.data.calendar_list[0];\n\n    return primaryCal.calendar_id;\n  } catch (err) {\n    throw new Error(`Failed to get calendar list: ${err instanceof Error ? err.message : String(err)}`);\n  }\n}\n\nasync function createEvent(client: Lark.Client, params: FeishuCalendarParams) {\n  if (!params.summary || !params.start_time || !params.end_time) {\n    return { error: \"Missing required fields: summary, start_time, end_time\" };\n  }\n\n  // Get the actual calendar ID instead of using \"primary\"\n  const calendarId = await getPrimaryCalendarId(client);\n\n  const body: any = {\n    summary: params.summary,\n    description: params.description || \"\",\n    start_time: { timestamp: toTimestamp(params.start_time), timezone: \"Asia/Shanghai\" },\n    end_time: { timestamp: toTimestamp(params.end_time), timezone: \"Asia/Shanghai\" },\n    visibility: params.visibility || \"default\",\n  };\n\n  if (params.location) {\n    body.location = { name: params.location };\n  }\n\n  if (params.attendees && params.attendees.length > 0) {\n    body.attendees = params.attendees.map((id) => ({\n      type: \"user\",\n      user_id: id,\n    }));\n  }\n\n  const resp: any = await client.calendar.calendarEvent.create({\n    path: { calendar_id: calendarId },\n    params: { user_id_type: \"open_id\" },\n    data: body,\n  });\n\n  if (resp.code !== 0) {\n    throw new Error(resp.msg || `Failed to create event: ${resp.code}`);\n  }\n\n  return {\n    event_id: resp.data?.event?.event_id,\n    summary: resp.data?.event?.summary,\n    start_time: resp.data?.event?.start_time,\n    end_time: resp.data?.event?.end_time,\n    attendees: resp.data?.event?.attendees,\n  };\n}\n\nasync function getEvent(client: Lark.Client, eventId: string) {\n  const resp: any = await client.calendar.event.get({\n    path: { event_id: eventId },\n  });\n\n  if (resp.code !== 0) {\n    throw new Error(resp.msg || `Failed to get event: ${resp.code}`);\n  }\n\n  return resp.data?.event;\n}\n\nasync function updateEvent(client: Lark.Client, eventId: string, params: FeishuCalendarParams) {\n  const body: any = {};\n  \n  if (params.summary) body.summary = params.summary;\n  if (params.description !== undefined) body.description = params.description;\n  if (params.start_time) {\n    body.start_time = { timestamp: toTimestamp(params.start_time), timezone: \"Asia/Shanghai\" };\n  }\n  if (params.end_time) {\n    body.end_time = { timestamp: toTimestamp(params.end_time), timezone: \"Asia/Shanghai\" };\n  }\n  if (params.location) body.location = { name: params.location };\n  if (params.visibility) body.visibility = params.visibility;\n  \n  if (params.attendees) {\n    body.attendees = params.attendees.map((id) => ({\n      type: \"user\",\n      user_id: id,\n    }));\n  }\n\n  const resp: any = await client.calendar.event.patch({\n    path: { event_id: eventId },\n    data: body,\n  });\n\n  if (resp.code !== 0) {\n    throw new Error(resp.msg || `Failed to update event: ${resp.code}`);\n  }\n\n  return { event_id: eventId, updated: true };\n}\n\nasync function deleteEvent(client: Lark.Client, eventId: string) {\n  const resp: any = await client.calendar.event.delete({\n    path: { event_id: eventId },\n  });\n\n  if (resp.code !== 0) {\n    throw new Error(resp.msg || `Failed to delete event: ${resp.code}`);\n  }\n\n  return { event_id: eventId, deleted: true };\n}\n\nexport function registerFeishuCalendarTools(api: OpenClawPluginApi) {\n  const accounts = listEnabledFeishuAccounts(api.config);\n  if (accounts.length === 0) return;\n\n  const firstAccount = accounts[0];\n  const toolsCfg = resolveToolsConfig(firstAccount.config.tools);\n  if (toolsCfg.calendar === false) return;\n\n  const getClient = () => createFeishuClient(firstAccount);\n\n  api.registerTool({\n    name: \"feishu_calendar\",\n    label: \"Feishu Calendar\",\n    description: \"Create and manage Feishu calendar events. Actions: create, update, delete, get\",\n    parameters: FeishuCalendarSchema,\n    async execute(_toolCallId, params) {\n      const p = params as FeishuCalendarParams;\n      try {\n        const client = getClient();\n        \n        if (p.action === \"create\") {\n          return json(await createEvent(client, p));\n        }\n        \n        if (p.action === \"get\") {\n          if (!p.event_id) return json({ error: \"Missing event_id\" });\n          return json(await getEvent(client, p.event_id));\n        }\n        \n        if (p.action === \"update\") {\n          if (!p.event_id) return json({ error: \"Missing event_id\" });\n          return json(await updateEvent(client, p.event_id, p));\n        }\n        \n        if (p.action === \"delete\") {\n          if (!p.event_id) return json({ error: \"Missing event_id\" });\n          return json(await deleteEvent(client, p.event_id));\n        }\n        \n        return json({ error: `Unknown action: ${(p as any).action}` });\n      } catch (err) {\n        return json({ error: err instanceof Error ? err.message : String(err) });\n      }\n    },\n  }, { name: \"feishu_calendar\" });\n\n  api.logger.info?.(\"feishu_calendar: Registered\");\n}\n"}],"isError":false,"timestamp":1772357686758}}
