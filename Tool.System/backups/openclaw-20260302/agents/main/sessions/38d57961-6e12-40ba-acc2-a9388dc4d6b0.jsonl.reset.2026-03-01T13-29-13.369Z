"none\",\n      \"color\": -1,\n      \"create_time\": \"1772357922\",\n      \"description\": \"参与人: 伟哥、许雯祯、杨哲（大眼）\",\n      \"end_time\": {\n        \"timestamp\": \"1772438400\",\n        \"timezone\": \"Asia/Shanghai\"\n      },\n      \"event_id\": \"b3a0e1c7-0dc6-46d5-a9fe-6091c5535eba_0\",\n      \"free_busy_status\": \"busy\",\n      \"is_exception\": false,\n      \"location\": {\n        \"address\": \"\",\n        \"latitude\": 0,\n        \"longitude\": 0,\n        \"name\": \"教学中心\"\n      },\n      \"organizer_calendar_id\": \"feishu.cn_XPhMNlWBS0qz08CnYIrb0g@group.calendar.feishu.cn\",\n      \"recurrence\": \"\",\n      \"self_rsvp_status\": \"accept\",\n      \"start_time\": {\n        \"timestamp\": \"1772416800\",\n        \"timezone\": \"Asia/Shanghai\"\n      },\n      \"status\": \"confirmed\",\n      \"summary\": \"教学中心集中办公\",\n      \"visibility\": \"default\"\n    }\n  },\n  \"msg\": \"success\"\n}","cwd":"/Users/liuwei/.openclaw/workspace"},"isError":false,"timestamp":1772357922761}}
