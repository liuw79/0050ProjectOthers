{"type":"message","id":"367a2fd5","parentId":"2ecd247c","timestamp":"2026-03-01T09:36:44.687Z","message":{"role":"assistant","content":[{"type":"text","text":"之前飞书日历接口报 400 错误。我直接调试一下这个接口，看看具体是什么问题："},{"type":"toolCall","id":"call_3e7ac71698d54b04a68c92da","name":"exec","arguments":{"command":"cd ~/openclaw/extensions/feishu && node -e '\nconst Lark = require(\"@larksuiteoapi/node-sdk\");\nconst fs = require(\"fs\");\n\n// 读取 OpenClaw 配置获取 token\nconst configPath = process.env.HOME + \"/.openclaw/config.json\";\nconst config = JSON.parse(fs.readFileSync(configPath, \"utf8\"));\nconst feishuCfg = config.channels?.find(c => c.id === \"feishu\")?.config || {};\n\nconst client = new Lark.Client({\n  appId: feishuCfg.app_id,\n  appSecret: feishuCfg.app_secret,\n});\n\nasync function test() {\n  // 1. 列出日历\n  const calList = await client.calendar.calendar.list({ params: { page_size: 50 } });\n  console.log(\"Calendars:\", JSON.stringify(calList, null, 2));\n  \n  // 2. 获取主日历 ID\n  const primaryCal = calList.data?.calendar_list?.find(c => c.primary) || calList.data?.calendar_list?.[0];\n  console.log(\"Primary:\", primaryCal?.calendar_id, primaryCal?.summary);\n}\n\ntest().catch(e => console.error(\"Error:\", e.message));\n'","timeout":30}}],"api":"anthropic-messages","provider":"zai","model":"glm-5","usage":{"input":746,"output":300,"cacheRead":34816,"cacheWrite":0,"totalTokens":35862,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772357787819}}
