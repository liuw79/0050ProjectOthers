/* pages/index/index.wxss - 真机优化版本 */

.container {
  padding: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 历史图片区域 */
.history-section {
  width: 90%;
  max-width: 600px;
  margin-bottom: 20px;
}

.history-title {
  font-size: 14px;
  color: #666;
  margin-bottom: 10px;
}

.history-scroll {
  width: 100%;
  white-space: nowrap;
}

.history-list {
  display: inline-flex;
  gap: 10px;
}

.history-item {
  display: inline-block;
  width: 80px;
  height: 80px;
  border-radius: 4px;
  overflow: hidden;
  border: 2px solid #e0e0e0;
  box-sizing: border-box;
}

.history-image {
  width: 100%;
  height: 100%;
}

.image-container {
  width: 90%;
  max-width: 600px;
  margin: 20px 0;
  padding: 20px;
  border: 2px dashed #ccc;
  border-radius: 8px;
  display: flex;
  justify-content: center;
  align-items: center;
  background-color: #f8f8f8;
  min-height: 150px;
}

.placeholder-text {
  color: #999;
  font-size: 16px;
}

.watermark-textarea {
  width: 90%;
  max-width: 600px;
  margin: 20px 0;
  padding: 10px;
  height: 80px;
  border: 1px solid #ddd;
  border-radius: 4px;
  font-size: 16px;
  box-sizing: border-box;
}

.generate-btn {
  width: 90%;
  max-width: 300px;
  margin: 20px 0;
}